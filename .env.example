# ── Supabase ──────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here        # client-side alias
SUPABASE_SERVICE_ROLE_KEY=                        # server-side only, never expose

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-...                             # Netlify functions only

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Site / CORS ───────────────────────────────────────────
SITE_URL=https://your-domain.com                  # production origin for CORS
CORS_EXTRA_ORIGINS=https://staging.your-domain.com  # comma-separated extras

# ── Audit Defense ─────────────────────────────────────────
# Do not set AUDIT_DEFENSE_BYPASS_PAYMENT=true (server rejects it).
AUDIT_DEFENSE_SERVICE_KEY=                        # server-to-server only

# ── Analytics ─────────────────────────────────────────────
# Set your real Measurement ID; inject into <meta name="ga-measurement-id"> on deploy (see README).
GA_MEASUREMENT_ID=
